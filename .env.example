# 注塑成型工艺参数智能推荐系统 - 环境变量配置

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# 大模型 API 配置
# ============================================
# LLM API 密钥
LLM_API_KEY=your_api_key_here

# LLM 模型名称 (默认: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# LLM API 基础 URL (如果使用自定义端点)
LLM_BASE_URL=

# 温度参数 (0.0-1.0, 默认: 0.7)
LLM_TEMPERATURE=0.7

# 最大 token 数 (默认: 4096)
LLM_MAX_TOKENS=4096
